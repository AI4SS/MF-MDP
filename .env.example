# =============================================================================
# MF-MDP 环境变量配置
# 复制此文件为 .env 并根据你的实际路径修改
# =============================================================================

# -----------------------------------------------------------------------------
# 项目路径配置
# -----------------------------------------------------------------------------
# 项目根目录（可选，脚本会自动检测）
# PROJECT_ROOT=/path/to/MF-MDP

# -----------------------------------------------------------------------------
# 数据集路径
# -----------------------------------------------------------------------------
# 事件数据目录
EVENT_DATA_DIR=./data/events

# 用户画像文件
PROFILE_PATH=./main/data/profile/cluster_core_user_profile.jsonl

# -----------------------------------------------------------------------------
# 模型路径
# -----------------------------------------------------------------------------
# 状态转移模型检查点
STATE_MODEL_CHECKPOINT=./checkpoints/event_transformer/event_transformer_best.pt

# 策略模型路径
POLICY_MODEL_PATH=./models/qwen2-1.5B_policy

# 均值场模型路径
MF_MODEL_PATH=./models/qwen2-1.5B_mf

# 模型基础目录
MODEL_BASE_DIR=./models/

# -----------------------------------------------------------------------------
# vLLM API 配置
# -----------------------------------------------------------------------------
VLLM_API_BASE=http://localhost:8000/v1
VLLM_MODEL_NAME=deepseek-chat

# -----------------------------------------------------------------------------
# 输出和缓存路径
# -----------------------------------------------------------------------------
OUTPUT_DIR=./main/result
CACHE_DIR=./cache/text_embeddings
PRED_STATE_DIR=./data/pred_state_distribution
